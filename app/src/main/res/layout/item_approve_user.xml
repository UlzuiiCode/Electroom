<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvApproveNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama User"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvApproveEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvApproveRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Role: -"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvApproveNimNip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NIM/NIP: -"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnRejectUser"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tolak"
                android:textColor="@android:color/holo_red_dark" />

            <Button
                android:id="@+id/btnApproveUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setujui"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>